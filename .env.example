# ── Garmin ───────────────────────────────────────────────────────────────────
GARMIN_EMAIL=jouw@email.com
GARMIN_PASSWORD=jouwwachtwoord

# ── Google Sheets ─────────────────────────────────────────────────────────────
# Vind je Sheet ID in de URL: docs.google.com/spreadsheets/d/SHEET_ID_HIER/edit
GOOGLE_SHEET_ID=jouw_sheet_id_hier

# Pad naar het service account JSON bestand dat je downloadt van Google Cloud
GOOGLE_SERVICE_ACCOUNT_JSON=./service_account.json

# Naam van het tabblad in je Google Sheet
SHEET_TAB_NAME=coach_data

# ── Claude API (voor de coaching in de app) ───────────────────────────────────
# Haal op via console.anthropic.com
VITE_CLAUDE_API_KEY=sk-ant-...

# ── Google Sheets API (voor de React app) ─────────────────────────────────────
# Zelfde Sheet ID als hierboven
VITE_GOOGLE_SHEET_ID=jouw_sheet_id_hier

# Service account email (staat in het JSON bestand, veld "client_email")
VITE_GOOGLE_SERVICE_ACCOUNT_EMAIL=coach@jouwproject.iam.gserviceaccount.com

# Private key van het service account (staat in het JSON bestand, veld "private_key")
# Kopieer de volledige key inclusief -----BEGIN en END-----
VITE_GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
